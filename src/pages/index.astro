---
import Layout from "@/layouts/Layout.astro";

import About from "@/containers/About.astro";
import Work from "@/containers/Work.astro";
import Experience from "@/containers/Experience.astro";
import Awards from "@/containers/Awards.astro";
import Skills from "@/containers/Skills.astro";
import Socials from "@/containers/Socials.astro";
import Faqs from "@/containers/Faqs.astro";
import Footer from "@/containers/Footer.astro";

import Header from "@/components/Header.astro";
---

<Layout>
